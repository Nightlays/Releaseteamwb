+            ${t.id === 'roles' && html`<path d="M8 2l1.5 4.5H14l-3.8 2.8 1.4 4.5L8 11.2l-3.6 2.6 1.4-4.5L2 6.5h4.5z"/>`}
+            ${t.id === 'users' && html`<circle cx="8" cy="5.5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M11 2l1.5 1.5M12.5 2L11 3.5" stroke-width="1.2"/>`}
+          </svg>
+          ${t.label}
+          ${t.count != null && html`<span class="dp-tab-count">${t.count}</span>`}
+        </button>`)}
+      </div>
+      <div class="dp-modal-body">
+
+        ${tab === 'team' && html`<div class="dp-modal-pane">
+          <div class="dp-team-table-wrap">
+            <table class="dp-team-table">
+              <thead><tr>
+                <th>Участник</th><th>Роль</th><th>Модулей</th><th>Доступы</th>
+              </tr></thead>
+              <tbody>
+                ${managedUsers.map(u => {
+                  const rId = u.login === 'Nightlays' ? 'superadmin' : (u.role || 'viewer');
+                  const rLabel = roles.find(r => r.id === rId)?.label || rId;
+                  const allowed = resolveAllowedForUser(u.login, rId, accessMap, userAccessMap, modules);
+                  const mods = modules.filter(m => allowed.has(m.id));
+                  const isCurrent = u.login === currentUser;
+                  return html`<tr key=${u.login} class=${isCurrent ? 'current' : ''}>
+                    <td><div class="dp-tt-name">${u.login}${isCurrent && html`<span class="dp-tt-you">Текущий</span>`}</div></td>
+                    <td><span class="dp-role-badge" data-role=${rId}>${rLabel}</span></td>
+                    <td><strong>${mods.length === modules.length ? 'Все' : mods.length}</strong></td>
+                    <td><div class="dp-tt-modules">${mods.map(m => html`<span key=${m.id} class="dp-tt-tag">${m.label}</span>`)}</div></td>
+                  </tr>`;
+                })}
+              </tbody>
+            </table>
+          </div>
+          <div class="dp-table-footer">${managedUsers.length} участников</div>
+        </div>`}
+
+        ${tab === 'roles' && html`<div class="dp-modal-pane">
+          <div class="dp-roles-layout">
+            <div class="dp-col-side">
+              <div class="dp-col-head" style="background:inherit">Роли</div>
+              <div class="dp-col-list">
+                ${roles.map(r => {
+                  const list = (localAccess[r.id] ?? accessMap[r.id]) || [];
+                  const cnt = list.includes('*') ? 'Все' : list.length;
+                  return html`<button key=${r.id} class=${'dp-role-btn' + (selRole === r.id ? ' active' : '')}
+                    onClick=${() => setSelRole(r.id)}>
+                    <span>${r.label}</span>
+                    <span class="dp-role-count">${cnt}</span>
+                  </button>`;
+                })}
+              </div>
+            </div>
+            <div class="dp-col-main">
+              <div class="dp-col-head">
+                <span>${roles.find(r => r.id === selRole)?.label || 'Роль'}</span>
+                <div class="dp-col-actions">
+                  <button class="dp-btn dp-btn-secondary dp-btn-sm" onClick=${() => setLocalAccess(p => ({...p,[selRole]:['*']}))}>Все</button>
+                  <button class="dp-btn dp-btn-secondary dp-btn-sm" onClick=${() => setLocalAccess(p => ({...p,[selRole]:[] }))}>Сброс</button>
+                </div>
+              </div>
+              <div class="dp-module-grid">
+                ${modules.map(m => {
+                  const allowed = getAllowed(selRole);
+                  const checked = allowed.has(m.id);
+                  return html`<label key=${m.id} class="dp-access-item">
+                    <input type="checkbox" checked=${checked} onChange=${e => {
+                      const cur = [...(getAllowed(selRole))];
+                      const next = e.target.checked ? [...cur, m.id] : cur.filter(x => x !== m.id);
+                      setLocalAccess(p => ({...p,[selRole]:next}));
+                    }} />
+                    <span>${m.label}</span>
+                  </label>`;
+                })}
+              </div>
+              <div class="dp-save-row">
+                <button class="dp-btn dp-btn-primary" onClick=${async () => {
+                  const next = {...accessMap};
+                  Object.keys(localAccess).forEach(k => { next[k] = localAccess[k]; });
+                  await onSaveAccess(next);
+                  setLocalAccess({});
+                  showToast('Доступы сохранены', 'success', { title: 'RBAC' });
+                }}>Сохранить доступы роли</button>
+              </div>
+            </div>
+          </div>
+        </div>`}
+
+        ${tab === 'users' && html`<div class="dp-modal-pane">
+          <div class="dp-create-strip">
+            <div class="dp-create-strip-head">Создать пользователя</div>
+            <div class="dp-create-grid">
+              <div class="dp-field"><label>Никнейм</label>
+                <input value=${newLogin} onInput=${e => setNewLogin(e.target.value)} placeholder="Artem" autocomplete="off"/>
+              </div>
+              <div class="dp-field"><label>Пароль</label>
+                <input type="password" value=${newPass} onInput=${e => setNewPass(e.target.value)} placeholder="Пароль" autocomplete="new-password"/>
+              </div>
+              <div class="dp-field"><label>Роль</label>
+                <select value=${newRole} onChange=${e => setNewRole(e.target.value)}>
+                  ${roles.filter(r => r.id !== 'superadmin').map(r => html`<option key=${r.id} value=${r.id}>${r.label}</option>`)}
+                </select>
+              </div>
+              <button class="dp-btn dp-btn-primary" style="height:38px" onClick=${async () => {
+                if (!newLogin.trim() || !newPass.trim()) { showToast('Заполните никнейм и пароль', 'warning'); return; }
+                await onCreateUser({ login: newLogin.trim(), pass: newPass.trim(), role: newRole });
+                setNewLogin(''); setNewPass('');
+                showToast('Пользователь создан', 'success', { title: 'Пользователи' });
+              }}>Создать</button>
+            </div>
+          </div>
+          <div class="dp-users-layout">
+            <div class="dp-col-side" style="display:flex;flex-direction:column">
+              <div class="dp-col-head" style="background:inherit">Участники</div>
+              <div class="dp-col-list">
+                ${managedUsers.map(u => {
+                  const rId = u.login === 'Nightlays' ? 'superadmin' : (u.role || 'viewer');
+                  const rLabel = roles.find(r => r.id === rId)?.label || rId;
+                  return html`<button key=${u.login} class=${'dp-user-btn' + (selUser === u.login ? ' active' : '')}
+                    onClick=${() => setSelUser(u.login)}>
+                    <span>${u.login}</span>
+                    <span class="dp-user-rolebadge">${rLabel}</span>
+                  </button>`;
+                })}
+              </div>
+            </div>
+            <div class="dp-edit-col">
+              <div class="dp-col-head">Настройки участника</div>
+              <div class="dp-edit-section">
+                <div class="dp-field"><label>Роль</label>
+                  <select value=${editRole} disabled=${selUser === 'Nightlays'}
+                    onChange=${e => setEditRole(e.target.value)}>
+                    ${selUser === 'Nightlays'
+                      ? html`<option value="superadmin">Суперадмин</option>`
+                      : roles.filter(r => r.id !== 'superadmin').map(r => html`<option key=${r.id} value=${r.id}>${r.label}</option>`)
+                    }
+                  </select>
+                </div>
+                <div class="dp-field"><label>Новый пароль</label>
+                  <input type="password" value=${userPass} onInput=${e => setUserPass(e.target.value)} placeholder="Оставьте пустым"/>
+                </div>
+                <label class="dp-toggle-row">
+                  <input type="checkbox" checked=${userEditUseRole} disabled=${selUser === 'Nightlays'}
+                    onChange=${e => setUserEditUseRole(e.target.checked)}/>
+                  Использовать доступы роли
+                </label>
+                <div class="dp-module-grid">
+                  ${modules.map(m => {
+                    const allowed = getUserAllowed();
+                    const checked = allowed.has(m.id);
+                    const disabled = selUser === 'Nightlays' || userEditUseRole;
+                    return html`<label key=${m.id} class="dp-access-item">
+                      <input type="checkbox" checked=${checked} disabled=${disabled}
+                        onChange=${e => {/* handled via save */}}/>
+                      <span>${m.label}</span>
+                    </label>`;
+                  })}
+                </div>
+                <div class="dp-save-row" style="margin:0 -14px -14px;padding:12px 14px">
+                  <button class="dp-btn dp-btn-primary" onClick=${async () => {
+                    if (!selUser) return;
+                    const checkboxes = document.querySelectorAll('.dp-edit-section .dp-access-item input[type=checkbox]');
+                    const access = Array.from(checkboxes).filter(c => c.checked && !c.disabled).map(c => {
+                      const label = c.closest('label')?.querySelector('span')?.textContent;
+                      return modules.find(m => m.label === label)?.id;
+                    }).filter(Boolean);
+                    await onSaveUser(selUser, { role: editRole, pass: userPass || null, useRole: userEditUseRole, access });
+                    showToast('Пользователь сохранён', 'success', { title: 'Пользователи' });
+                  }}>Сохранить участника</button>
+                </div>
+              </div>
+            </div>
+          </div>
+        </div>`}
+
+      </div>
+    </div>
+  </div>`;
+}
+
+// ── AuthScreen ─────────────────────────────────────────────────────────────
+function AuthScreen({ onAuth }) {
+  const [loginVal, setLoginVal] = useState('');
+  const [passVal, setPassVal] = useState('');
+  const [err, setErr] = useState('');
+
+  function handleSubmit(e) {
+    e.preventDefault();
+    const doAuth = (users) => {
+      const l = loginVal.trim(), p = passVal.trim();
+      const found = (users || []).find(u => u.login === l && u.pass === p);
+      if (!found) { setErr('Неверный логин или пароль'); return; }
+      setErr('');
+      // Replicate original role logic: only Nightlays gets superadmin
+      let r = found.role || 'viewer';
+      if (l === 'Nightlays') r = 'superadmin';
+      else if (r === 'superadmin') r = 'admin';
+      localStorage.setItem('rb_auth_ok_v1', '1');
+      localStorage.setItem('rb_user_v1', found.login);
+      localStorage.setItem('rb_role_v1', r);
+      onAuth(found.login, r);
+    };
+    // Use already-loaded RB_CONFIG first (synchronous), fall back to loadRbConfig()
+    if (Array.isArray(window.RB_CONFIG?.users) && window.RB_CONFIG.users.length) {
+      doAuth(window.RB_CONFIG.users);
+    } else if (typeof window.loadRbConfig === 'function') {
+      window.loadRbConfig().then(cfg => doAuth(cfg?.users));
+    } else {
+      setErr('Конфигурация не загружена');
+    }
+  }
+
+  return html`<div class="dp-auth">
+    <form class="dp-auth-card" onSubmit=${handleSubmit} autocomplete="off">
+      <div class="dp-auth-title">Вход</div>
+      <div class="dp-auth-note">Доступ к дашборду по логину и паролю</div>
+      <div class="dp-auth-field">
+        <label>Логин</label>
+        <input value=${loginVal} onInput=${e => setLoginVal(e.target.value)} placeholder="Введите логин" autocomplete="username"/>
+      </div>
+      <div class="dp-auth-field">
+        <label>Пароль</label>
+        <input type="password" value=${passVal} onInput=${e => setPassVal(e.target.value)} placeholder="Введите пароль" autocomplete="current-password"/>
+      </div>
+      <div class="dp-auth-error">${err}</div>
+      <button type="submit" class="dp-auth-btn">Войти</button>
+    </form>
+  </div>`;
+}
+
+// ── App ────────────────────────────────────────────────────────────────────
+function App() {
+  const [authed, setAuthed] = useState(() => localStorage.getItem(AUTH_KEY) === '1');
+  const [role, setRole] = useState(() => localStorage.getItem(ROLE_KEY) || 'viewer');
+  const [login, setLogin] = useState(() => localStorage.getItem(USER_KEY) || '');
+  const [theme, setTheme] = useState(() => localStorage.getItem(THEME_KEY) || 'theme-wb-dark');
+  const [collapsed, setCollapsed] = useState(() => localStorage.getItem(SIDEBAR_KEY) === '1');
+  const [navOpen, setNavOpen] = useState(false);
+  const [activeModule, setActiveModule] = useState('dashboard_run_module.html');
+  const [menuOpen, setMenuOpen] = useState(false);
+  const [themeOpen, setThemeOpen] = useState(false);
+  const [modal, setModal] = useState(null); // null | { tab: 'team'|'roles'|'users' }
+  const [rbac, setRbac] = useState({ roles: [], users: [], accessMap: {}, userAccessMap: {} });
+  const [proxyConfig, setProxyConfig] = useState(() => loadRuntimeProxy());
+  const [toast, showToast] = useToast();
+  const iframeRef = useRef(null);
+
+  // Load RBAC on mount
+  useEffect(() => {
+    const load = window.loadRbConfig ? window.loadRbConfig() : Promise.resolve({});
+    load.then(cfg => {
+      const roles = Array.isArray(cfg?.roles) && cfg.roles.length ? cfg.roles : [
+        { id: 'superadmin', label: 'Суперадмин' },
+        { id: 'admin', label: 'Администратор' },
+        { id: 'manager', label: 'Менеджер' },
+        { id: 'analyst', label: 'Аналитик' },
+        { id: 'viewer', label: 'Наблюдатель' },
+      ];
+      const users = Array.isArray(cfg?.users) ? cfg.users : [];
+      const defAccess = getDefaultAccess(MODULES);
+      const accessMap = { ...defAccess, ...(cfg?.roleAccess || {}) };
+      try { const local = JSON.parse(localStorage.getItem(ACCESS_KEY) || '{}'); Object.assign(accessMap, local); } catch {}
+      const userAccessMap = { ...(cfg?.userAccess || {}) };
+      try { const local = JSON.parse(localStorage.getItem(USER_ACCESS_KEY) || '{}'); Object.assign(userAccessMap, local); } catch {}
+      setRbac({ roles, users, accessMap, userAccessMap });
+    });
+
+    // Listen for role change events from auth script
+    const handler = e => {
+      const r = e.detail?.role || 'viewer';
+      const u = e.detail?.user || '';
+      setRole(r); setLogin(u);
+      document.body.dataset.role = r;
+      document.body.classList.toggle('role-admin', r === 'admin');
+      document.body.classList.toggle('role-superadmin', r === 'superadmin');
+    };
+    const usersHandler = () => {
+      const load = window.loadRbConfig ? window.loadRbConfig() : Promise.resolve({});
+      load.then(cfg => {
+        setRbac(prev => ({
+          ...prev,
+          users: Array.isArray(cfg?.users) ? cfg.users : prev.users,
+        }));
+      });
+    };
+    window.addEventListener('rb-role-changed', handler);
+    window.addEventListener('rb-users-updated', usersHandler);
+    return () => { window.removeEventListener('rb-role-changed', handler); window.removeEventListener('rb-users-updated', usersHandler); };
+  }, []);
+
+  // Apply theme
+  useEffect(() => {
+    THEME_IDS.forEach(id => document.body.classList.remove(id));
+    document.body.classList.add(theme);
+    localStorage.setItem(THEME_KEY, theme);
+  }, [theme]);
+
+  // Sidebar collapse
+  useEffect(() => {
+    localStorage.setItem(SIDEBAR_KEY, collapsed ? '1' : '0');
+  }, [collapsed]);
+
+  // Apply role classes
+  useEffect(() => {
+    document.body.dataset.role = role;
+    document.body.classList.toggle('role-admin', role === 'admin');
+    document.body.classList.toggle('role-superadmin', role === 'superadmin');
+    document.body.classList.toggle('authed', authed);
+    document.body.classList.toggle('rb-locked', !authed);
+  }, [role, authed]);
+
+  // Module URL update
+  useEffect(() => {
+    if (!iframeRef.current || !activeModule) return;
+    const url = buildProxyUrl(activeModule, proxyConfig);
+    if (iframeRef.current.src !== url) iframeRef.current.src = url;
+    try {
+      const u = new URL(location.href);
+      u.searchParams.set('module', activeModule);
+      window.history.replaceState({}, '', u.toString());
+    } catch {}
+  }, [activeModule, proxyConfig]);
+
+  // Init active module from URL
+  useEffect(() => {
+    const param = new URLSearchParams(location.search).get('module');
+    if (param && MODULES.find(m => m.id === param)) setActiveModule(param);
+  }, []);
+
+  // Fallback to the first accessible module if the current one was removed or hidden by access rules.
+  useEffect(() => {
+    if (!authed) return;
+    const allowed = resolveAllowedForUser(login, role, rbac.accessMap, rbac.userAccessMap, MODULES);
+    const current = MODULES.find(m => m.id === activeModule);
+    const currentAllowed = current && allowed.has(current.id) && isModuleAllowed(current.id, role);
+    if (currentAllowed) return;
+    const fallback = MODULES.find(m => allowed.has(m.id) && isModuleAllowed(m.id, role) && !m.openNewTab)
+      || MODULES.find(m => allowed.has(m.id) && isModuleAllowed(m.id, role));
+    if (fallback && fallback.id !== activeModule) setActiveModule(fallback.id);
+  }, [authed, activeModule, login, role, rbac.accessMap, rbac.userAccessMap]);
+
+  // Expose showToast globally for backwards compat
+  useEffect(() => { window.__dpShowToast = showToast; }, [showToast]);
+
+  function handleActivate(item) {
+    if (!item?.id) return;
+    if (item.openNewTab) { window.open(new URL(item.id, location.href).toString(), '_blank', 'noopener'); return; }
+    const allowed = resolveAllowedForUser(login, role, rbac.accessMap, rbac.userAccessMap, MODULES);
+    if (!allowed.has(item.id)) { showToast('Модуль недоступен', 'warning', { title: 'Доступ' }); return; }
+    if (!isModuleAllowed(item.id, role)) { showToast('Требуются права суперадмина', 'warning', { title: 'Доступ' }); return; }
+    setActiveModule(item.id);
+    setNavOpen(false);
+  }
+
+  function handleLogout() {
+    localStorage.removeItem(AUTH_KEY);
+    localStorage.removeItem(ROLE_KEY);
+    localStorage.removeItem(USER_KEY);
+    setAuthed(false); setRole('viewer'); setLogin('');
+    document.body.classList.remove('authed'); document.body.classList.add('rb-locked');
+  }
+
+  function handleAuth(u, r) { setAuthed(true); setLogin(u); setRole(r); }
+
+  async function handleSaveAccess(newAccessMap) {
+    setRbac(prev => ({ ...prev, accessMap: newAccessMap }));
+    localStorage.setItem(ACCESS_KEY, JSON.stringify(newAccessMap));
+    if (typeof window.saveRbConfigSource === 'function') {
+      try { await window.saveRbConfigSource({ roles: rbac.roles, users: rbac.users, roleAccess: newAccessMap, userAccess: rbac.userAccessMap }); } catch (e) { showToast(e.message, 'warning'); }
+    }
+  }
+
+  async function handleSaveUser(userLogin, data) {
+    const { role: newRole, pass, useRole, access } = data;
+    // Update role
+    const users = rbac.users.map(u => u.login === userLogin ? { ...u, role: newRole } : u);
+    const userAccessMap = { ...rbac.userAccessMap, [userLogin]: { useRole, access: access || [] } };
+    setRbac(prev => ({ ...prev, users, userAccessMap }));
+    localStorage.setItem(USER_ACCESS_KEY, JSON.stringify(userAccessMap));
+    if (typeof window.saveRbConfigSource === 'function') {
+      try { await window.saveRbConfigSource({ roles: rbac.roles, users, roleAccess: rbac.accessMap, userAccess: userAccessMap }); } catch (e) { showToast(e.message, 'warning'); }
+    }
+  }
+
+  async function handleCreateUser(data) {
+    if (typeof window.addRbCustomUser === 'function') window.addRbCustomUser(data);
+    setRbac(prev => ({ ...prev, users: [...prev.users, data] }));
+  }
+
+  const managedUsers = rbac.users.filter(u => u.login && u.pass);
+  const roleLabel = rbac.roles.find(r => r.id === role)?.label || role;
+
+  if (!authed) return html`<${AuthScreen} onAuth=${handleAuth}/>`;
+
+  return html`<div>
+    <${TopBar}
+      role=${role} roleLabel=${roleLabel}
+      menuOpen=${menuOpen} themeOpen=${themeOpen} currentTheme=${theme}
+      onMenuToggle=${() => { setMenuOpen(p => !p); if (!menuOpen) setThemeOpen(false); }}
+      onThemeToggle=${() => setThemeOpen(p => !p)}
+      onThemeSelect=${t => { setTheme(t); setThemeOpen(false); }}
+      onProfile=${() => setModal({ tab: 'team' })}
+      onAccess=${() => setModal({ tab: role === 'superadmin' ? 'roles' : 'users' })}
+      onLogout=${handleLogout}
+      onNavToggle=${() => setNavOpen(p => !p)}
+    />
+    <div class=${'dp-shell' + (collapsed ? ' collapsed' : '') + (navOpen ? ' nav-open' : '')}>
+      <${Sidebar}
+        collapsed=${collapsed} role=${role} login=${login}
+        activeModule=${activeModule}
+        accessMap=${rbac.accessMap} userAccessMap=${rbac.userAccessMap}
+        onActivate=${handleActivate}
+        onToggle=${() => { if (window.innerWidth <= 980) setNavOpen(false); else setCollapsed(p => !p); }}
+      />
+      <div class="dp-content">
+        <iframe ref=${iframeRef} class="dp-iframe" id="rbModuleFrame" title="Модуль" src=${activeModule}/>
+      </div>
+    </div>
+    ${modal && html`<${TeamModal}
+      open=${true} initTab=${modal.tab}
+      role=${role} login=${login}
+      roles=${rbac.roles} modules=${MODULES}
+      accessMap=${rbac.accessMap} userAccessMap=${rbac.userAccessMap}
+      managedUsers=${managedUsers}
+      onClose=${() => setModal(null)}
+      onSaveAccess=${handleSaveAccess}
+      onSaveUser=${handleSaveUser}
+      onCreateUser=${handleCreateUser}
+      showToast=${showToast}
+    />`}
+    <div class=${'dp-toast' + (toast.show ? ' show' : '')}>
+      <div class="dp-toast-kind">${toast.kind}</div>
+      <div>
+        <div class="dp-toast-title">${toast.title}</div>
+        <div class="dp-toast-msg">${toast.msg}</div>
+      </div>
+    </div>
+  </div>`;
+}
+
+// ── Mount ──────────────────────────────────────────────────────────────────
+preactRender(html`<${App}/>`, document.getElementById('root'));
+
+</script>
+
 </body>
 </html>
