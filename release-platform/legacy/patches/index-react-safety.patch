+/* ═══ SHELL CSS — Дом Питона v4 (React) ═══════════════════════════════════ */
+:root {
+  --topbar-h: 56px;
+  --sidebar-w: 252px;
+  --sidebar-w-collapsed: 56px;
+  --nav-item-h: 38px;
+  --nav-radius: 7px;
+  --nav-active-bg: color-mix(in srgb, var(--wb) 14%, var(--btn-bg) 86%);
+  --nav-hover-bg:  color-mix(in srgb, var(--wb) 7%,  var(--btn-bg) 93%);
+  --sidebar-bg:    color-mix(in srgb, var(--card) 90%, var(--wb) 10%);
+}
+html, body { height: 100%; overflow: hidden; margin: 0; padding: 0; }
+
+/* ── Topbar ─────────────────────────────── */
+.dp-topbar {
+  position: sticky; top: 0; z-index: 30;
+  height: var(--topbar-h);
+  display: flex; align-items: center;
+  padding: 0 clamp(12px,1.2vw,18px);
+  gap: 8px;
+  background: color-mix(in srgb, var(--card) 86%, transparent);
+  border-bottom: 1px solid var(--line);
+  backdrop-filter: blur(20px) saturate(160%);
+  -webkit-backdrop-filter: blur(20px) saturate(160%);
+}
+.dp-brand {
+  display: flex; align-items: center; gap: 9px; flex-shrink: 0;
+  text-decoration: none;
+}
+.dp-brand-mark {
+  width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
+  display: flex; align-items: center; justify-content: center;
+  font-size: 10.5px; font-weight: 800; letter-spacing: .6px; color: #fff;
+  background: linear-gradient(135deg, var(--wb-deep) 0%, var(--wb) 100%);
+  box-shadow: 0 2px 8px color-mix(in srgb, var(--wb) 40%, transparent),
+              inset 0 1px 0 rgba(255,255,255,.24);
+  font-family: 'Inter', system-ui, sans-serif;
+}
+.dp-brand-text { line-height: 1; }
+.dp-brand-name {
+  font-size: 14px; font-weight: 700; letter-spacing: -.25px;
+  color: var(--text); font-family: 'Inter', system-ui, sans-serif;
+}
+.dp-brand-sub {
+  font-size: 10px; font-weight: 500; color: var(--muted); margin-top: 1px;
+  letter-spacing: .05px;
+}
+.dp-topbar-spacer { flex: 1; }
+.dp-topbar-actions { display: flex; align-items: center; gap: 6px; }
+
+/* Role chip */
+.dp-role-chip {
+  display: inline-flex; align-items: center;
+  height: 26px; padding: 0 10px; border-radius: 999px;
+  font-size: 10.5px; font-weight: 700; letter-spacing: .35px;
